# ─────────────────────────────────────────────
#  ProyectoTesis — .gitignore unificado
#  Cubre: backend (FastAPI), frontend (Vite/React/TS),
#         local (scripts Python embebidos), notebooks ML
# ─────────────────────────────────────────────

# ── Sistema operativo ────────────────────────
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ── IDEs y editores ──────────────────────────
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.user
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo

# ── Variables de entorno ─────────────────────
.env
.env.local
.env.*.local
*.env
!.env.example

# ── Python (backend + local + notebooks) ─────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
.Python
*.egg-info/
*.egg
.eggs/
pip-log.txt
pip-delete-this-directory.txt
.tox/
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pytype/

# Entornos virtuales
.venv/
venv/
env/
ENV/
backend/.venv/
local/.venv/

# ── Archivos de log ───────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Node / Frontend ───────────────────────────
node_modules/
frontend/node_modules/
dist/
dist-ssr/
frontend/dist/
*.local

# ── Jupyter Notebooks ─────────────────────────
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# ── Modelos ML (binarios grandes) ─────────────
# Los modelos entrenados se almacenan en Google Drive.
# Solo se versiona el código; los pesos se cargan en runtime.
*.pth
*.pt
*.onnx
*.h5
*.hdf5
*.pb
*.tflite
*.pkl
*.joblib
*.npy
*.npz
modelos/
local/modelos/
local/modelo_m1/

# ── Datasets (no versionar imágenes/CSVs grandes) ─
# Los CSVs de resultados en /resultados/ SÍ se versionan (son pequeños).
/data/
/datasets/
*.zip
*.tar.gz
*.tar.bz2

# ── Alembic migrations auto-generadas (mantener solo las manuales) ─
# Descomenta si quieres ignorar todas las versiones de alembic:
# backend/alembic/versions/*.py

# ── Base de datos local de desarrollo ─────────
*.sqlite3
*.db

# ── Archivos temporales de compilación TypeScript ─
*.tsbuildinfo
frontend/node_modules/.tmp/

# ── Certificados y credenciales ───────────────
*.pem
*.key
*.cert
*.crt
service_account.json
credentials.json
