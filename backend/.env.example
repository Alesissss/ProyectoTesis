# ── Base de datos ──────────────────────────────────────────────
# Formato: postgresql+asyncpg://usuario:contraseña@host:puerto/nombre_bd
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/vigilanceai

# ── JWT ────────────────────────────────────────────────────────
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CAMBIA_ESTO_POR_UN_SECRETO_SEGURO_DE_64_CHARS
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── CORS ───────────────────────────────────────────────────────
# Orígenes permitidos separados por coma
ALLOWED_ORIGINS=["http://localhost:5173", "http://localhost:3000", "http://localhost:5174"]

# ── App ────────────────────────────────────────────────────────
APP_NAME=VigilanceAI API
APP_VERSION=1.0.0
DEBUG=true
